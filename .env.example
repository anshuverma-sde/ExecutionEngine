# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Async SQLAlchemy URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/engine

# ── Redis ────────────────────────────────────────────────────────────────────
# DB 0: price window + cooldown keys
REDIS_URL=redis://redis:6379/0
# DB 1: Celery broker
CELERY_BROKER_URL=redis://redis:6379/1
# DB 2: Celery result backend
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── DhanHQ Feed ──────────────────────────────────────────────────────────────
# Obtain from https://dhanhq.co → API credentials
DHAN_CLIENT_ID=your_dhan_client_id_here
DHAN_ACCESS_TOKEN=your_dhan_access_token_here

# ── AI Layer (Groq — free tier, OpenAI-compatible) ───────────────────────────
# Obtain from https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Notification ─────────────────────────────────────────────────────────────
# Webhook endpoint that receives trade notifications (POST JSON)
WEBHOOK_URL=http://webhook-mock:8001/notify
# HTTP timeout in seconds for outbound notification requests
WEBHOOK_TIMEOUT_SECONDS=10

# ── Application ──────────────────────────────────────────────────────────────
# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# deployment environment label (development | staging | production)
ENVIRONMENT=development
